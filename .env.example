# ─── TikiTaka Mobile — Variables de Entorno ────────────────────────────────────
# Copia este archivo como .env.dev (desarrollo) o .env (producción)
# NUNCA subas archivos .env* al repositorio (ya están en .gitignore)
#
# Cómo obtener estos valores:
#   Supabase → Settings → API → Project URL y Project API Keys

# URL del proyecto en Supabase
EXPO_PUBLIC_SUPABASE_URL=

# Clave pública anon de Supabase (safe para el cliente)
EXPO_PUBLIC_SUPABASE_ANON_KEY=
